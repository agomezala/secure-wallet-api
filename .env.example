# ──────────────────────────────────────────────
# The Secure Wallet API — Environment Variables
# ──────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/secure_wallet

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
